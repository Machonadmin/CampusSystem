NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase service role key — from Project Settings → API in Supabase dashboard
SUPABASE_SECRET_KEY=your_supabase_service_role_key

# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_min_32_chars

# ── Error monitoring (Sentry) — optional; without a DSN Sentry is a no-op ──
# Server + client DSN (NEXT_PUBLIC_ is exposed to the browser, required for client errors).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Environment label shown in Sentry (defaults to VERCEL_ENV / 'production').
NEXT_PUBLIC_SENTRY_ENV=
# Source-map upload at build time (Vercel only). Leave empty to skip upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

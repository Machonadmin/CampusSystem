# ─── Пример переменных окружения для STAGING ─────────────────────────────────
# Скопируйте значения из нового проекта Supabase (staging) и вставьте их в
# Vercel → Settings → Environment Variables проекта staging.
# Файл-ШАБЛОН: реальные ключи сюда НЕ коммитим (см. .gitignore: .env*.local).

# Supabase → Project Settings → Data API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-STAGING-REF.supabase.co

# Supabase → Project Settings → API Keys → anon / publishable key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-staging-anon-key

# Supabase → Project Settings → API Keys → service_role / secret key (НЕ публичный!)
SUPABASE_SECRET_KEY=your-staging-service-role-key

# Любая случайная строка минимум 32 символа. Сгенерировать:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-random-string-at-least-32-chars-long

# ── Error monitoring (Sentry) — optional; without a DSN Sentry is a no-op ──
# Server + client DSN (NEXT_PUBLIC_ is exposed to the browser, required for client errors).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
# Environment label shown in Sentry (defaults to VERCEL_ENV / 'production').
NEXT_PUBLIC_SENTRY_ENV=
# Source-map upload at build time (Vercel only). Leave empty to skip upload.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
